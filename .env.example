# Burned Value — Environment Configuration
# Copy this file to .env and fill in your values for local development.
# For Docker, set these in docker-compose.yml instead.

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-change-in-production

# Data directory for project JSON files (default: ./data)
# DATA_DIR=./data

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: "claude" | "ollama" | "none"
AI_PROVIDER=none

# ── Option A: Claude (Anthropic cloud) ───────────────────────────────────────
# AI_PROVIDER=claude
# AI_MODEL=claude-opus-4-5
# AI_API_KEY=sk-ant-...

# ── Option B: Ollama (on-premise) ────────────────────────────────────────────
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434
# AI_MODEL=llama3
# AI_API_KEY=        ← not needed for Ollama
